# Database (Supabase — Transaction Pooler, port 6543 required for serverless)
# Dashboard > Project Settings > Database > Connection string > Transaction
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Direct connection — migrations only (prisma migrate dev/deploy)
# Dashboard > Project Settings > Database > Connection string > Direct
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs
STRIPE_PRICE_STANDARD=""
STRIPE_PRICE_FEATURED=""
STRIPE_PRICE_BUNDLE=""

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="noreply@example.com"
