generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// TAXONOMY
// ─────────────────────────────────────────────

model Category {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  parentId String?

  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("SubCategories")
  jobs     Job[]

  @@index([parentId])
  @@map("categories")
}

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  jobs JobTag[]

  @@map("tags")
}

model JobTag {
  jobId String
  tagId String

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([jobId, tagId])
  @@map("job_tags")
}

// ─────────────────────────────────────────────
// COMPANIES
// ─────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  description String?
  website     String?
  city        String?
  size        String?
  techStack   String[]
  verified    Boolean  @default(false)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs      Job[]
  employers Employer[]

  @@map("companies")
}

// ─────────────────────────────────────────────
// JOBS
// ─────────────────────────────────────────────

enum RemoteType {
  REMOTE
  HYBRID
  ON_SITE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

enum JobStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  CLOSED
}

model Job {
  id              String          @id @default(cuid())
  slug            String          @unique
  title           String
  description     String
  salaryMin        Int?
  salaryMax        Int?
  salaryCurrency   String          @default("EUR")
  salaryDisclosed  Boolean         @default(true)
  city            String?
  remoteType      RemoteType      @default(ON_SITE)
  employmentType  EmploymentType  @default(FULL_TIME)
  experienceLevel ExperienceLevel @default(MID)
  applyType           String          @default("URL")
  applyUrl            String?
  applyEmail          String?
  coverLetter         String          @default("OPTIONAL")
  featured            Boolean         @default(false)
  isCurated           Boolean         @default(false)
  curatedCompanyName  String?
  status              JobStatus       @default(DRAFT)
  activeDays      Int             @default(0)
  inactiveDays    Int             @default(0)
  postedAt        DateTime?
  expiresAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  companyId  String?
  categoryId String

  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  category    Category     @relation(fields: [categoryId], references: [id])
  tags        JobTag[]
  applyClicks ApplyClick[]

  @@index([status, postedAt])
  @@index([categoryId])
  @@index([remoteType])
  @@map("jobs")
}

// ─────────────────────────────────────────────
// EMPLOYERS (authenticated users who post jobs)
// ─────────────────────────────────────────────

enum EmployerPlan {
  FREE
  STARTER
  FEATURED
}

model Employer {
  id                  String       @id @default(cuid())
  email               String       @unique
  name                String?
  plan                EmployerPlan @default(FREE)
  stripeCustomerId    String?
  emailVerified       Boolean      @default(false)
  verifyToken         String?      @unique
  verifyTokenExpiry   DateTime?
  onboardingCompleted  Boolean      @default(false)
  loginToken           String?      @unique
  loginTokenExpiry     DateTime?
  standardSlots        Int          @default(0)
  featuredSlots        Int          @default(0)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  blocked   Boolean  @default(false)

  @@map("employers")
}

// ─────────────────────────────────────────────
// APPLY CLICKS (admin analytics)
// ─────────────────────────────────────────────

model ApplyClick {
  id        String   @id @default(cuid())
  jobId     String
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("apply_clicks")
}

// ─────────────────────────────────────────────
// BLOG POSTS (admin-managed)
// ─────────────────────────────────────────────

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  author      String   @default("CyprusTech.Jobs Editorial")
  authorRole  String   @default("Editorial")
  publishedAt DateTime @default(now())
  readTime    Int      @default(5)
  category    String
  tags        String[]
  content     Json     @default("[]")
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blog_posts")
}

// ─────────────────────────────────────────────
// SLOT PURCHASES (idempotency log for Stripe payments)
// ─────────────────────────────────────────────

model SlotPurchase {
  id          String   @id @default(cuid())
  sessionId   String   @unique
  employerId  String
  standardQty Int
  featuredQty Int
  createdAt   DateTime @default(now())

  @@map("slot_purchases")
}

// ─────────────────────────────────────────────
// JOB ALERTS (candidates subscribe, no account needed)
// ─────────────────────────────────────────────

model JobAlert {
  id              String           @id @default(cuid())
  email           String
  firstName       String?
  categoryId      String?
  companyId       String?
  remoteType      RemoteType?
  city            String?
  experienceLevel ExperienceLevel?
  salaryMin       Int?
  alertFrequency  String           @default("WEEKLY")
  confirmed       Boolean          @default(false)
  token           String           @unique @default(cuid())
  createdAt       DateTime         @default(now())
  lastSentAt      DateTime?

  @@unique([email, categoryId, remoteType, companyId])
  @@map("job_alerts")
}
